rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "digidentityagency@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isCollaborator() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'collaborator';
    }

    function isClient() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'client';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============ USERS ============
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isCollaborator());
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin()
      );
      allow create: if isAuthenticated() && (
        isAdmin() || (isOwner(userId) && request.resource.data.role == 'client')
      );
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read, update: if isOwner(userId) || isAdmin();
        allow create, delete: if isAdmin();
      }
    }

    // ============ SETTINGS ============
    match /settings/studio {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /studio_settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============ CONVERSATIONS ============
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && resource.data.client_id == request.auth.uid)
      );
      allow create: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && request.resource.data.client_id == request.auth.uid)
      );
      allow update, delete: if isAdmin() || isCollaborator();
    }

    // ============ MESSAGES (flat collection) ============
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && (
          resource.data.client_id == request.auth.uid ||
          exists(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)) &&
          get(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)).data.client_id == request.auth.uid
        ))
      );
      allow create: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && request.resource.data.sender_id == request.auth.uid)
      );
      allow update, delete: if isAdmin();
    }

    // ============ DEADLINES ============
    match /deadlines/{deadlineId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && resource.data.client_id == request.auth.uid)
      );
      allow create, update, delete: if isAdmin() || isCollaborator();
    }

    // ============ DOCUMENTS ============
    match /documents/{documentId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && resource.data.client_id == request.auth.uid)
      );
      allow create: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && request.resource.data.client_id == request.auth.uid)
      );
      allow update, delete: if isAdmin() || isCollaborator();
    }

    // ============ INVOICES ============
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        isAdmin() || (isClient() && resource.data.client_id == request.auth.uid)
      );
      allow write: if isAdmin();
    }

    // ============ PAYMENTS ============
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        isAdmin() || (isClient() && resource.data.client_id == request.auth.uid)
      );
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ============ PRACTICES ============
    match /practices/{practiceId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && resource.data.client_id == request.auth.uid)
      );
      allow create, update: if isAdmin() || isCollaborator();
      allow delete: if isAdmin();
    }

    // ============ CLIENTS ============
    match /clients/{clientId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && resource.data.profile_id == request.auth.uid)
      );
      allow create, update, delete: if isAdmin() || isCollaborator();
    }

    // ============ COLLABORATORS ============
    match /collaborators/{collaboratorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============ NOTIFICATIONS ============
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isCollaborator() ||
        (isClient() && resource.data.user_id == request.auth.uid)
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() || resource.data.user_id == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ============ AI (admin only) ============
    match /orchestrator_status/{docId} {
      allow read, write: if isAdmin();
    }

    match /ai_subagents/{subagentId} {
      allow read: if isAdmin() || isCollaborator();
      allow write: if isAdmin();
    }

    match /ai_activity_log/{logId} {
      allow read: if isAdmin() || isCollaborator();
      allow write: if isAdmin();
    }

    // === NEW RULES v2.0 ===

    // === CONTACTS ===
    match /contacts/{contactId} {
      allow read: if isAdmin() || isCollaborator();
      allow write: if isAdmin();
      // Le Cloud Functions scrivono tramite Admin SDK (bypassano le rules)
    }

    // === AGENT_SESSIONS ===
    match /agent_sessions/{sessionId} {
      // Lettura: admin, collaboratori, o se il session_token corrisponde
      allow read: if isAdmin() || isCollaborator() || 
        resource.data.session_token == request.auth.token.session_token;
      // Creazione: chiunque può creare una sessione (il chatbot pubblico non è autenticato)
      allow create: if true;
      // Aggiornamento: solo admin/collaboratori (e Cloud Functions via Admin SDK)
      allow update: if isAdmin() || isCollaborator();
    }

    // === APPOINTMENTS ===
    match /appointments/{appointmentId} {
      allow read: if isAdmin() || isCollaborator();
      allow write: if isAdmin();
    }

    // === AVAILABILITY ===
    match /availability/{docId} {
      allow read: if true;  // pubblico — serve per mostrare slot disponibili
      allow write: if isAdmin();
    }

    // === KNOWLEDGE_BASE ===
    match /knowledge_base/{docId} {
      allow read: if isAdmin() || isCollaborator();
      allow write: if isAdmin();
    }
  }
}

